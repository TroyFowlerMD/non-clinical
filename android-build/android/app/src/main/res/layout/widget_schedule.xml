<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:id="@+id/widget_header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Schedule"
            android:textStyle="bold"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="6dp"
            android:src="@android:drawable/ic_popup_sync"
            android:contentDescription="Refresh" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_switcher_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <Button
            android:id="@+id/widget_button_schedule"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="Schedule"
            android:textAllCaps="false"
            android:textSize="11sp"
            android:padding="0dp" />

        <Button
            android:id="@+id/widget_button_backup"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Backup"
            android:textAllCaps="false"
            android:textSize="11sp"
            android:padding="0dp" />

        <Button
            android:id="@+id/widget_button_calendar"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Calendar"
            android:textAllCaps="false"
            android:textSize="11sp"
            android:padding="0dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginTop="6dp">

        <TextView android:id="@+id/widget_line_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" />
        <TextView android:id="@+id/widget_line_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="2dp" />
        <TextView android:id="@+id/widget_line_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="2dp" />
        <TextView android:id="@+id/widget_line_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="2dp" />
        <TextView android:id="@+id/widget_line_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="2dp" />
        <TextView android:id="@+id/widget_line_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="2dp" />
        <TextView android:id="@+id/widget_line_7" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="2dp" />
        <TextView android:id="@+id/widget_line_8" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="2dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_last_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last updated: -"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_stale"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stale data (>24h)"
        android:textSize="11sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:visibility="gone" />
</LinearLayout>