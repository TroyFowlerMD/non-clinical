<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/jfk_widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_previous"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="&lt;"
            android:textColor="#f7f5ef"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#26313a" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:text="JFK Schedule"
            android:textColor="#f7f5ef"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_next"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="&gt;"
            android:textColor="#f7f5ef"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#26313a" />

        <TextView
            android:id="@+id/widget_refresh"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginLeft="6dp"
            android:gravity="center"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:text="Refresh"
            android:textColor="#f7f5ef"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="#26313a" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="Label"
            android:textColor="#b8c0c6"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="Psych"
            android:textColor="#b8c0c6"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="Medical"
            android:textColor="#b8c0c6"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#20272c"
        android:dividerHeight="1dp"
        android:cacheColorHint="#00000000" />

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="12dp"
        android:text="Open app to load today's schedule."
        android:textColor="#b8c0c6"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="6dp"
        android:text="Schedule data as of -"
        android:textColor="#b8c0c6"
        android:textSize="10sp" />
</LinearLayout>
