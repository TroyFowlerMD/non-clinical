<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.DogWhistle" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/dw_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:colorBackground">@color/dw_background</item>
        <item name="android:colorForeground">@color/dw_text</item>
        <item name="colorPrimary">@color/dw_primary</item>
        <item name="colorSecondary">@color/dw_secondary</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>
</resources>

